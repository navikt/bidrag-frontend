{
    "name": "@bidrag/api",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "exports": {
        ".": {
            "import": "./src/index.ts"
        },
        "./*": {
            "import": "./src/api/*.ts"
        }
    },
    "scripts": {
        "typecheck": "tsc --noEmit",
        "api:person": "swagger-typescript-api -p https://bidrag-person-q2.intern.dev.nav.no/bidrag-person/v3/api-docs --axios -n PersonApi.ts -o src/api",
        "api:sak": "swagger-typescript-api -p https://bidrag-sak-q2.intern.dev.nav.no/v3/api-docs --axios -n SakApi.ts -o src/api",
        "api:tilgangskontroll": "swagger-typescript-api -p https://bidrag-tilgangskontroll.intern.dev.nav.no/v3/api-docs --axios -n TilgangskontrollApi.ts -o src/api",
        "api:samhandler": "swagger-typescript-api -p https://bidrag-samhandler-q2.intern.dev.nav.no/v3/api-docs --axios -n SamhandlerApi.ts -o src/api",
        "api:organisasjon": "swagger-typescript-api -p https://bidrag-organisasjon-feature.intern.dev.nav.no/bidrag-organisasjon/v3/api-docs --axios -n OrganisasjonApi.ts -o src/api",
        "api:belopshistorikk": "swagger-typescript-api -p https://bidrag-belopshistorikk-q2.intern.dev.nav.no/v3/api-docs --axios -n BelopshistorikkApi.ts -o src/api",
        "api:bidragVedtak": "swagger-typescript-api -p https://bidrag-vedtak-q2.intern.dev.nav.no/v3/api-docs --axios -n BidragVedtakApi.ts -o src/api",
        "api:reskontro": "swagger-typescript-api -p https://bidrag-reskontro-q2.intern.dev.nav.no/v3/api-docs --axios -n BidragReskontroApi.ts -o src/api"

    },
    "dependencies": {
        "@bidrag/types": "workspace:*",
        "@bidrag/common": "workspace:*",
        "axios": "^1.18.0",
        "@tanstack/react-query": "catalog:",
        "@types/node": "^25"
    },
    "devDependencies": {
        "swagger-typescript-api": "13.0.23"
    }
}
