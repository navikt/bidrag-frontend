{
    "name": "bidrag-frontend",
    "private": true,
    "scripts": {
        "build": "pnpm run -r build",
        "build:web": "pnpm --filter web build",
        "dev": "printf \"\\033[1;33m%s\\033[0m\\n\" \"Bruk frontend via Wonderwall: http://localhost:4000 (ikke http://localhost:3000)\" && pnpm --filter web dev",
        "typecheck": "pnpm -r run typecheck",
        "lint": "biome lint .",
        "lint:changed": "biome lint --changed --since=origin/main",
        "biome:ci": "biome ci",
        "biome:ci:changed": "biome ci --changed --since=origin/main",
        "format": "biome format .",
        "check": "biome check .",
        "check:changed": "biome check --changed --since=origin/main",
        "check:changed:write": "biome check --write --changed --since=origin/main",
        "test": "pnpm -r --if-present run test",
        "deploy:clean": "rm -rf deploy_dist",
        "deploy:web": "pnpm --filter web --prod --legacy deploy deploy_dist",
        "deploy:docker": "pnpm run build && pnpm run deploy:clean && pnpm run deploy:web"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.5.0",
        "@types/node": "^25.9.3",
        "@types/react": "catalog:",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9"
    },
    "engines": {
        "node": ">=24",
        "pnpm": ">=11"
    },
    "packageManager": "pnpm@11.9.0"
}
