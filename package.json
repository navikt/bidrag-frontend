{
    "name": "bidrag-frontend",
    "private": true,
    "scripts": {
        "build": "pnpm run -r build",
        "build:web": "pnpm --filter web build",
        "dev": "pnpm --filter web dev",
        "typecheck": "pnpm -r run typecheck",
        "lint": "biome lint .",
        "format": "biome format --write .",
        "check": "biome check --write .",
        "test": "pnpm -r --if-present run test",
        "deploy:clean": "rm -rf deploy_dist",
        "deploy:web": "pnpm --filter web --prod --legacy deploy deploy_dist",
        "deploy:docker": "pnpm run build && pnpm run deploy:clean && pnpm run deploy:web"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.5.0",
        "@types/node": "^25.9.3",
        "@types/react": "catalog:",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9"
    },
    "engines": {
        "node": ">=24",
        "pnpm": ">=11"
    },
    "packageManager": "pnpm@11.9.0"
}
