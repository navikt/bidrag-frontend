{
    "extends": "../../tsconfig.base.json",
    "include": [
        "app",
        ".react-router/types/**/*"
    ],
    "compilerOptions": {
        "rootDirs": [
            ".",
            "./.react-router/types"
        ],
        "types": [
            "node",
            "react",
            "react-dom",
            "vite/client"
        ],
        "paths": {
            "~/*": [
                "./app/*"
            ],
            "nais.js": [
                "./app/nais.d.ts"
            ]
        }
    }
}
