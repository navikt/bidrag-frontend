{
    "extends": "../../tsconfig.base.json",
    "include": [
        "app",
        ".react-router/types/**/*"
    ],
    "compilerOptions": {
        "types": ["node", "react", "react-dom"],
        "paths": {
            "~/*": [
                "./app/*"
            ],
            "+/*": [
                "./.react-router/types/app/*"
            ],
            "nais.js": [
                "./app/nais.d.ts"
            ]
        }
    }
}
